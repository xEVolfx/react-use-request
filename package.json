{
  "name": "@xevolfx/react-use-request",
  "version": "0.1.1",
  "description": "Lightweight React hooks for async request management with abort, loading, and status state",
  "keywords": [
    "react",
    "hooks",
    "request",
    "async",
    "abort",
    "typescript"
  ],
  "license": "MIT",
  "author": "xEVolfx",
  "homepage": "https://github.com/xEVolfx/react-use-request#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xEVolfx/react-use-request.git"
  },
  "bugs": {
    "url": "https://github.com/xEVolfx/react-use-request/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky || true",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.2",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "happy-dom": "^20.9.0",
    "lint-staged": "^15.5.1",
    "prettier": "^3.5.3",
    "react": "^19.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "tests/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
